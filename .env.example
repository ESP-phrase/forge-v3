# === Database ===
# Postgres connection from Neon, Vercel Postgres, or Supabase.
# Use the pooled URL for runtime. If your provider gives a separate direct URL,
# put it in DIRECT_DATABASE_URL — Prisma uses it for migrations.
DATABASE_URL=postgres://...
DIRECT_DATABASE_URL=postgres://...

# === Auth ===
# Required for Auth.js sessions. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (optional — primary signup path; set to enable 1-tap)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Twitter/X OAuth (optional)
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# === App URLs ===
# NEXT_PUBLIC_APP_URL=https://www.seoforge.org
# NEXT_PUBLIC_BLOG_URL=https://blog.seoforge.org

# === AI (required) ===
# Google AI Studio API key (https://aistudio.google.com/apikey)
# Free tier: 1,500 requests/day on Gemini Flash — no credit card needed.
GOOGLE_API_KEY=

# === Email (optional — skipped if unset) ===
# Transactional email (Resend — https://resend.com/api-keys) for welcome and
# billing notifications.
RESEND_API_KEY=
# Sender — use "onboarding@resend.dev" for testing without a verified domain.
EMAIL_FROM=onboarding@resend.dev

# === Stripe ===
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_HOBBY_MONTHLY=
# STRIPE_PRICE_HOBBY_ANNUAL=
# STRIPE_PRICE_OPERATOR_MONTHLY=
# STRIPE_PRICE_OPERATOR_ANNUAL=
# STRIPE_PRICE_AGENCY_MONTHLY=
# STRIPE_PRICE_AGENCY_ANNUAL=
# STRIPE_PRICE_HOBBY_TRIAL=
# STRIPE_PRICE_OPERATOR_TRIAL=
# STRIPE_PRICE_AGENCY_TRIAL=
# STRIPE_PRICE_VARIANT_B_TRIAL=
# STRIPE_PRICE_VARIANT_B_STARTER=

# === SEO Tools ===
# SerpApi key (https://serpapi.com/manage-api-key) — competitive SERP analysis
# before generating each article. Free tier: 100 searches/month.
SERPAPI_KEY=

# Unsplash Access Key (https://unsplash.com/developers) — hero image for articles.
# Free demo tier: 50 requests/hour. Leave blank to skip images.
UNSPLASH_ACCESS_KEY=

# Encryption key for storing WordPress Application Passwords at rest.
# Must be 32 bytes base64-encoded. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# === Cron ===
# Token used by Vercel Cron to authenticate scheduled runs.
# Generate any random string. Vercel Cron sends it as Authorization: Bearer <token>.
CRON_SECRET=

# === Vercel Custom Domains ===
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

# === Ad Pixels (all optional — skipped if unset) ===
# TikTok
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_PIXEL_ID=D846P43C77U6NFPBOPMG
# NEXT_PUBLIC_TIKTOK_PIXEL_ID=D846P43C77U6NFPBOPMG

# Reddit
# REDDIT_CAPI_TOKEN=
# REDDIT_PIXEL_ID=a2_j0nbovdr0uc1
# NEXT_PUBLIC_REDDIT_PIXEL_ID=a2_j0nbovdr0uc1

# Google Ads
# NEXT_PUBLIC_GOOGLE_ADS_ID=
# NEXT_PUBLIC_GOOGLE_ADS_LABEL=

# Microsoft Ads
# NEXT_PUBLIC_MICROSOFT_UET_ID=
# NEXT_PUBLIC_MICROSOFT_UET_GOAL=

# Microsoft Clarity
# NEXT_PUBLIC_CLARITY_ID=

# === Social posting (stubs — integrations not yet live) ===
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=
# REDDIT_USER_AGENT=auto-seo

# === Dev / Debug ===
# ADMIN_QUICK_LOGIN= — bypass login in dev (set to any truthy value)
